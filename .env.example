# Email Configuration for Portfolio Contact Form
# ================================================

# YOUR GMAIL ADDRESS
GMAIL_USER=zulkeflrehman@gmail.com

# YOUR GMAIL APP PASSWORD
# ⚠️ IMPORTANT: Generate a Gmail App Password (NOT your regular password!)
# Steps to get your App Password:
# 1. Go to https://myaccount.google.com/security
# 2. Enable "2-Step Verification" if not already enabled
# 3. Go to https://myaccount.google.com/apppasswords
# 4. Select "Mail" and "Windows PC"
# 5. Copy the 16-character password (without spaces)
# 6. Paste it below

GMAIL_PASSWORD=your_16_character_app_password_here

# Email subject prefix (optional)
EMAIL_SUBJECT_PREFIX=[Portfolio Contact]

# Port for the server
PORT=3000
